<Window x:Class="KeyR.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize" SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        LocationChanged="Window_LocationChanged"
        Icon="pack://application:,,,/appIcon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource InputBox}"/>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Border" Width="16" Height="16" Background="{DynamicResource ThemeCheckBg}" BorderBrush="{DynamicResource ThemeCheckBorder}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center">
                                <Border x:Name="CheckFill" Margin="3" CornerRadius="2" Background="{DynamicResource ThemeAccent}" Visibility="Hidden" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckFill" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ThemeCheckHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <ToggleButton Grid.ColumnSpan="2" Focusable="false" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" BorderThickness="0" Background="Transparent">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path Fill="{DynamicResource ThemeTextSecondary}" Data="M 0 0 L 3.5 4 L 7 0 Z" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter IsHitTestVisible="False" Margin="{TemplateBinding Padding}" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeInputBorder}" BorderThickness="1" CornerRadius="4" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=border}">
                                    <ScrollViewer Margin="0,2" SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="2" Margin="2,1">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeBtnHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="MoveBtnStyle">
            <Setter Property="Background" Value="{DynamicResource ThemeAppBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeAppBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="HeaderBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeBtnHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeHoverText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="CloseBtn" BasedOn="{StaticResource HeaderBtn}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeDanger}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeBtnHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeDangerHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Use ToggleButton for Tabs to handle states perfectly with DynamicResource -->
        <Style TargetType="ToggleButton" x:Key="TabBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeTabSelectedBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTabSelectedText}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeTabHoverBg}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Focusable="True" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown">
        <!-- Custom ToolTip Layer -->
        <Popup x:Name="HoverTooltip" Placement="Absolute" AllowsTransparency="True" IsOpen="False" IsHitTestVisible="False">
            <Border Background="{DynamicResource ThemeTooltipBg}" BorderBrush="{DynamicResource ThemeTooltipBorder}" BorderThickness="1" CornerRadius="6" Padding="10,6">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                <TextBlock x:Name="TxtHoverTooltip" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="11" FontWeight="SemiBold"/>
            </Border>
        </Popup>

        <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="20" BorderThickness="1.5" BorderBrush="{DynamicResource ThemeCardBorder}" Margin="12">
            <Border.Effect>
                <DropShadowEffect Color="#050510" BlurRadius="15" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>

            <Grid Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid>
                    <TextBlock Text="SETTINGS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource HeaderBtn}" Click="BtnMinimize_Click" Margin="0,0,4,0" Tag="Minimize">
                            <Path Data="M4,11 h16 v3 h-16 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="3" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource CloseBtn}" Click="BtnClose_Click" Tag="Close">
                            <Path Data="M19,6.41L17.59,5,12,10.59,6.41,5,5,6.41,10.59,12,5,17.59,6.41,19,12,13.41,17.59,19,19,17.59,13.41,12,19,6.41Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search Bar -->
                <Border Grid.Row="2" Background="{DynamicResource ThemeSectionBg}" BorderThickness="0" CornerRadius="8" Height="30" Padding="12,0">
                    <Grid>
                        <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}" CaretBrush="{DynamicResource ThemeTextPrimary}" BorderThickness="0" Padding="0" TextAlignment="Left" FontSize="12" VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="TxtSearchPlaceholder" Text="Search settings..." IsHitTestVisible="False" Foreground="{DynamicResource ThemeTextDim}" FontSize="12" VerticalAlignment="Center" Margin="2,0,0,0" Opacity="0.7"/>
                    </Grid>
                </Border>

                <!-- Tab Strip -->
                <Grid Grid.Row="4">
                    <Border Background="{DynamicResource ThemeTabBg}" CornerRadius="8" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="BtnTabBasic" Grid.Column="0" Content="Basic" Style="{StaticResource TabBtn}" Click="BtnTabBasic_Click"/>
                            <ToggleButton x:Name="BtnTabAdvanced" Grid.Column="1" Content="Advanced" Style="{StaticResource TabBtn}" Click="BtnTabAdvanced_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Content Area -->
                <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" MaxHeight="420">
                    <Grid>
                        <!-- BASIC TAB -->
                        <StackPanel x:Name="PanelBasic">
                            <!-- Accessibility -->
                            <Border x:Name="SectionAccessibility" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="ACCESSIBILITY" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemAlwaysOnTop" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <CheckBox x:Name="ChkAlwaysOnTop" Content="Always On Top" Foreground="{DynamicResource ThemeTextSecondary}" FontFamily="Segoe UI Semibold" FontSize="12" Checked="PrefsChanged" Unchecked="PrefsChanged" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel x:Name="ItemShowDeletion" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <CheckBox x:Name="ChkShowConfirmations" Content="Show Deletion Confirmations" Foreground="{DynamicResource ThemeTextSecondary}" FontFamily="Segoe UI Semibold" FontSize="12" Checked="PrefsChanged" Unchecked="PrefsChanged" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel x:Name="ItemThemeToggle" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Theme" Foreground="{DynamicResource ThemeTextSecondary}" FontFamily="Segoe UI Semibold" FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1" x:Name="CmbTheme" SelectionChanged="CmbTheme_SelectionChanged" Height="28">
                                                <ComboBoxItem Content="Dark" Tag="Dark"/>
                                                <ComboBoxItem Content="Light" Tag="Light"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Playback Settings -->
                            <Border x:Name="SectionPlayback" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PLAYBACK SETTINGS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemContinuous" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" x:Name="ChkContinuous" Content="Continuous Playback" Foreground="{DynamicResource ThemeTextSecondary}" FontFamily="Segoe UI Semibold" FontSize="12" Checked="PrefsChanged" Unchecked="PrefsChanged" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Name="TxtLoopCount" Tag="Loop Count" LostFocus="PrefsChanged" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Speed Settings -->
                            <Border x:Name="SectionSpeed" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="SPEED SETTINGS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemSpeed" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Speed Multiplier:" Style="{StaticResource LabelStyle}"/>
                                            <Button Grid.Column="1" x:Name="BtnResetSpeed" Content="Reset" Click="BtnResetSpeed_Click" Style="{StaticResource MoveBtnStyle}" Padding="8,0"/>
                                            <TextBox Grid.Column="3" x:Name="TxtSpeed" LostFocus="PrefsChanged" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Hotkeys -->
                            <Border x:Name="SectionHotkeys" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="HOTKEYS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemRecHotkey" Margin="0,0,0,8" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Record:" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Grid.Column="1" x:Name="TxtRecHotkey" GotFocus="TxtHotkey_GotFocus" PreviewKeyDown="TxtHotkey_PreviewKeyDown" LostFocus="TxtHotkey_LostFocus"/>
                                            <Button Grid.Column="2" Content="Reset" Click="BtnResetRecHotkey_Click" Style="{StaticResource MoveBtnStyle}" Padding="8,0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel x:Name="ItemPlayHotkey" Margin="0,0,0,8" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Play/Stop:" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Grid.Column="1" x:Name="TxtPlayHotkey" GotFocus="TxtHotkey_GotFocus" PreviewKeyDown="TxtHotkey_PreviewKeyDown" LostFocus="TxtHotkey_LostFocus"/>
                                            <Button Grid.Column="2" Content="Reset" Click="BtnResetPlayHotkey_Click" Style="{StaticResource MoveBtnStyle}" Padding="8,0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel x:Name="ItemPauseHotkey" MinHeight="26">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Pause:" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Grid.Column="1" x:Name="TxtPauseHotkey" GotFocus="TxtHotkey_GotFocus" PreviewKeyDown="TxtHotkey_PreviewKeyDown" LostFocus="TxtHotkey_LostFocus"/>
                                            <Button Grid.Column="2" Content="Reset" Click="BtnResetPauseHotkey_Click" Style="{StaticResource MoveBtnStyle}" Padding="8,0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ADVANCED TAB -->
                        <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                            <!-- Auto-Restart -->
                            <Border x:Name="SectionAutoRestart" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <TextBlock Text="AUTO-RESTART" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Button x:Name="BtnConditionHelp" Content="?" Style="{StaticResource MoveBtnStyle}" HorizontalAlignment="Right" Padding="10,2" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Tag="The macro monitors your screen while playing.&#x0a;If the condition(s) are met, it will immediately&#x0a;restart from the beginning."/>
                                        </Grid>
                                        <StackPanel Margin="0,6,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button x:Name="BtnToggleMatchLogic" Style="{StaticResource MoveBtnStyle}" Content="Match: ANY" Click="BtnToggleMatchLogic_Click" Padding="8,2" FontWeight="Bold" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,6,0"/>
                                                <Button x:Name="BtnToggleRestartMode" Style="{StaticResource MoveBtnStyle}" Content="Logic: PULSE" Click="BtnToggleRestartMode_Click" Padding="8,2" FontWeight="Bold" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </StackPanel>
                                            <Button x:Name="BtnToggleRestrictedMode" Style="{StaticResource MoveBtnStyle}" Content="Restricted: OFF" Click="BtnToggleRestrictedMode_Click" Padding="8,2" FontWeight="Bold" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel x:Name="ItemPolling" Margin="0,0,0,8">
                                        <Grid MinHeight="26">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Polling Interval (ms):" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Grid.Column="1" x:Name="TxtPollingInterval" Text="1000" LostFocus="PrefsChanged" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                                        </Grid>
                                    </StackPanel>

                                    <ItemsControl x:Name="ListConditions">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="CardBorder" Background="{DynamicResource ThemeItemBg}" BorderBrush="{DynamicResource ThemeItemBorder}" BorderThickness="1" CornerRadius="6" Padding="6,4" Margin="0,0,0,3" Cursor="Hand" MouseLeftButtonDown="ConditionCard_MouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="2"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox x:Name="EnableCheck" Grid.Column="0" IsChecked="{Binding IsEnabled}" Margin="0,0,8,0" Checked="PrefsChanged" Unchecked="PrefsChanged"/>
                                                        <TextBlock x:Name="TypeText" Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                        <Button Grid.Column="2" Content="✏️" Click="BtnEditCondition_Click" Style="{StaticResource MoveBtnStyle}" Background="Transparent" VerticalAlignment="Center" Tag="Edit"/>
                                                        <Button Grid.Column="4" Content="✕" Click="BtnDeleteCondition_Click" Style="{StaticResource MoveBtnStyle}" Foreground="{DynamicResource ThemeDanger}" Background="Transparent" VerticalAlignment="Center" Tag="Delete"/>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=EnableCheck, Path=IsChecked}" Value="False">
                                                        <Setter TargetName="CardBorder" Property="Opacity" Value="0.4"/>
                                                        <Setter TargetName="TypeText" Property="TextDecorations" Value="Strikethrough"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="+ Add Condition" Click="BtnAddCondition_Click" Style="{StaticResource MoveBtnStyle}" HorizontalAlignment="Center" Width="120" Padding="10,2" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Quick-Move -->
                            <Border x:Name="SectionPosition" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="QUICK-MOVE" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Content="?" Style="{StaticResource MoveBtnStyle}" HorizontalAlignment="Right" Padding="10,2" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Tag="Click a tile to instantly snap the macro window&#x0a;to specific areas of your screen, or enter&#x0a;exact X and Y coordinates manually."/>
                                    </Grid>
                                    
                                    <Grid HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Left: 3x3 Grid -->
                                            <ColumnDefinition Width="25"/>   <!-- Center: Fixed Spacer -->
                                            <ColumnDefinition Width="Auto"/> <!-- Right: Coordinates -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Side: 3x3 Grid -->
                                        <Grid Grid.Column="0" x:Name="ItemQuickMove" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="34"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                            </Grid.RowDefinitions>
                                            
                                            <Button Grid.Row="0" Grid.Column="0" Click="BtnMoveTL_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotTL" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="0" Grid.Column="1" Click="BtnMoveTC_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotTC" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="0" Grid.Column="2" Click="BtnMoveTR_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotTR" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>

                                            <Button Grid.Row="1" Grid.Column="0" Click="BtnMoveCL_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotCL" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="1" Grid.Column="1" Click="BtnMoveCC_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotCC" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="1" Grid.Column="2" Click="BtnMoveCR_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotCR" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>

                                            <Button Grid.Row="2" Grid.Column="0" Click="BtnMoveBL_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotBL" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="2" Grid.Column="1" Click="BtnMoveBC_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotBC" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                            <Button Grid.Row="2" Grid.Column="2" Click="BtnMoveBR_Click" Style="{StaticResource MoveBtnStyle}" Margin="2" Height="Auto">
                                                <Ellipse x:Name="DotBR" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Hidden"/>
                                            </Button>
                                        </Grid>

                                        <!-- Right Side: Coordinates -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Position" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="22,0,0,6"/>
                                            
                                            <Grid Margin="0,0,0,8" x:Name="ItemPosXY">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="X" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="TxtPosX" Height="22" Padding="4,0" VerticalContentAlignment="Center" LostFocus="PrefsChanged"/>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Y" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="TxtPosY" Height="22" Padding="4,0" VerticalContentAlignment="Center" LostFocus="PrefsChanged"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Foreign Macro Import -->
                            <Border x:Name="SectionMacroImport" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="FOREIGN MACRO IMPORT" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemImportMacros">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="InformaalTask" Click="BtnImportInformaalTask_Click" Style="{StaticResource MoveBtnStyle}" Tag="Import .txt"/>
                                            <Button Grid.Column="2" Content="TinyTask" Click="BtnImportTinyTask_Click" Style="{StaticResource MoveBtnStyle}" Tag="Import .rec"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Data Management -->
                            <Border x:Name="SectionDataManagement" Background="{DynamicResource ThemeSectionBg}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="DATA MANAGEMENT" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ItemImportExport">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="Import" Click="BtnImportSettings_Click" Style="{StaticResource MoveBtnStyle}" Tag="Import Settings"/>
                                            <Button Grid.Column="2" Content="Export" Click="BtnExportSettings_Click" Style="{StaticResource MoveBtnStyle}" Tag="Export Settings"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Global Overlay for Hotkey Listening -->
        <Border x:Name="GlobalOverlay" Background="{DynamicResource ThemeOverlayBg}" Visibility="Collapsed" Panel.ZIndex="200" CornerRadius="18" Margin="12" MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Listening For Hotkey..." Foreground="{DynamicResource ThemeTextPrimary}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Press ESC to cancel" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
