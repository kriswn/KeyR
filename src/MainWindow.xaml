<Window x:Class="KeyR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyR" Height="117" Width="300" MinWidth="300" MaxWidth="300" MinHeight="117" MaxHeight="117"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        Icon="appIcon.png"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged"
        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="Button" x:Key="CardBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}" />
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeBtnHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeHoverText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeBtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="HeaderBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,1">
                            <Rectangle Width="8" Height="1.2" Fill="{TemplateBinding Foreground}" Margin="0,10,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeHoverText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CloseBtn" BasedOn="{StaticResource HeaderBtn}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeDanger}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeDangerHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Popup Notification Layer -->
        <Popup x:Name="NotificationPopup" Placement="Center" AllowsTransparency="True" StaysOpen="False" IsOpen="False">
            <Border Background="{DynamicResource ThemeNotifBg}" CornerRadius="10" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource ThemeTooltipBorder}" MouseLeftButtonDown="NotificationPopup_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                <TextBlock x:Name="TxtNotification" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14" FontWeight="Bold"/>
            </Border>
        </Popup>

        <!-- Custom ToolTip Layer -->
        <Popup x:Name="HoverTooltip" Placement="Absolute" AllowsTransparency="True" IsOpen="False" IsHitTestVisible="False">
            <Border Background="{DynamicResource ThemeTooltipBg}" BorderBrush="{DynamicResource ThemeTooltipBorder}" BorderThickness="1" CornerRadius="6" Padding="10,6">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                <TextBlock x:Name="TxtHoverTooltip" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="11" FontWeight="SemiBold"/>
            </Border>
        </Popup>

        <Border x:Name="MainBorder" Background="{DynamicResource ThemeCardBg}" CornerRadius="20" BorderThickness="1.5" BorderBrush="{DynamicResource ThemeCardBorder}" Margin="12" VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect Color="#050510" BlurRadius="15" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
            
            <Grid Margin="10,6,10,12" Background="Transparent" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Title Bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock x:Name="TxtTitleName" Text="KeyR" Foreground="{DynamicResource ThemeTextMuted}" FontSize="13" FontWeight="Bold" Opacity="0.8" MaxWidth="140" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0">
                        <TextBlock x:Name="TxtTitleDuration" Text="" Foreground="{DynamicResource ThemeTextDim}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.9"/>
                        <Button Style="{StaticResource HeaderBtn}" Click="BtnMinimize_Click" Tag="Minimize" Margin="0,0,2,0"/>
                        <Button Style="{StaticResource CloseBtn}" Click="BtnClose_Click" Tag="Close">
                            <TextBlock Text="✕" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Main Controls -->
                <Grid Grid.Row="1" Margin="0,0,0,3">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly" PanningDeceleration="0.001" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="BtnLoad" Width="40" Height="40" Style="{StaticResource CardBtn}" Click="BtnLoad_Click" Tag="Load" Content="📂"/>
                            <Button x:Name="BtnSave" Width="40" Height="40" Style="{StaticResource CardBtn}" Click="BtnSave_Click" Tag="Save" Margin="2,0,0,0" Content="💾"/>

                            <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeDivider}" Margin="6,0"/>

                            <Button x:Name="BtnRec" Width="40" Height="40" Style="{StaticResource CardBtn}" Click="BtnRec_Click" Tag="Record">
                                <Ellipse x:Name="RecIndicator" Width="10" Height="10" Fill="{DynamicResource ThemeDanger}"/>
                            </Button>
                            <Button x:Name="BtnPlay" Width="40" Height="40" Style="{StaticResource CardBtn}" Click="BtnPlay_Click" Tag="Play" Margin="2,0,0,0">
                                <Polygon x:Name="PlayIndicator" Points="0,0 0,10 8,5" Fill="{DynamicResource ThemeAccent}" Margin="2,0,0,0"/>
                            </Button>

                            <Rectangle Width="1" Height="24" Fill="{DynamicResource ThemeDivider}" Margin="6,0"/>
                            <Button x:Name="BtnPrefs" Width="40" Height="40" Style="{StaticResource CardBtn}" Click="BtnOpenSettings_Click" Tag="Settings">
                                <TextBlock Text="⚙️" FontSize="14" Margin="0,1,0,0"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>

</Window>
